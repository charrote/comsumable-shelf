vars: {
  d2-config: {
    layout-engine: dagre
    pad: 15
  }
}

"灯板故障排查": {
  shape: text
  near: top-center
  style: {
    font-size: 18
    bold: true
  }
}

start: "灯板不工作"
start: {
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
  }
}

has_display: "数码管有显示?"
has_display: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

e1: "显示 E1"
e1: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

p1: "显示 Pn"
p1: {
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 1
    border-radius: 4
  }
}

standby: "显示站号"
standby: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

no_display: "无显示"
no_display: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

can_read: "页面能读取灯板信息?"
can_read: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

read_ok: "能 → 通信正常"
read_ok: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

read_fail: "不能 → 站号冲突"
read_fail: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

led_test: "LED 测试序列能运行?"
led_test: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

led_ok: "能但某个不亮 → LED 损坏"
led_ok: {
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 1
    border-radius: 4
  }
}

led_all_fail: "全部不亮 → 检查 LED 电源"
led_all_fail: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

detection: "储位状态检测不准?"
detection: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

detection_fix1: "检查 AD 值"
detection_fix1: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

detection_fix2: "调整判定值"
detection_fix2: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

detection_fix3: "执行校准"
detection_fix3: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

rs485_fix: "检查 RS485 接线 A+/B-"
rs485_fix: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

calibrate_fix: "重新校准"
calibrate_fix: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

check_led: "继续 → 检查 LED"
check_led: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

rs485_bus: "检查 RS485 总线"
rs485_bus: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

check_power: "检查电源 (12V, GND)"
check_power: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

start -> has_display
has_display -- "是" -> e1
has_display -- "否" -> no_display -> check_power
e1 -> rs485_fix
e1 -> p1
p1 -> calibrate_fix
standby -> can_read
no_display -> check_power
can_read -- "能" -> read_ok -> check_led
can_read -- "不能" -> read_fail -> rs485_bus
check_led -> led_test
led_test -- "是" -> led_ok
led_test -- "否" -> led_all_fail
led_all_fail -> led_all_fail
led_ok -> detection
detection -> detection_fix1
detection -> detection_fix2
detection -> detection_fix3