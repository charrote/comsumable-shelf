vars: {
  d2-config: {
    layout-engine: dagre
    pad: 15
  }
}

"主控板故障排查": {
  shape: text
  near: top-center
  style: {
    font-size: 18
    bold: true
  }
}

start: "主控板无法连接"
start: {
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 2
  }
}

run_led: "RUN 灯状态?"
run_led: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

slow_blink: "慢闪"
slow_blink: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

fast_blink: "快闪"
fast_blink: {
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 1
    border-radius: 4
  }
}

off: "熄灭"
off: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

check_power: "检查供电"
check_power: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

network_led: "网口灯亮?"
network_led: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

network_on: "亮 → 物理连接正常"
network_on: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

network_off: "不亮 → 检查网线"
network_off: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

dip_switch: "拨码设置正确?"
dip_switch: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

config_mode: "配置模式 (00)"
config_mode: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

eth_mode: "以太网 DHCP (01)"
eth_mode: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

wifi_mode: "WiFi 模式 (10)"
wifi_mode: {
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 1
    border-radius: 4
  }
}

can_ping: "PC 能 ping 通?"
can_ping: {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
  }
}

ping_ok: "能 → 尝试连接"
ping_ok: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

ping_fail: "不能 → 检查网络/防火墙"
ping_fail: {
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 1
    border-radius: 4
  }
}

try_connect: "尝试连接"
try_connect: {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 1
    border-radius: 4
  }
}

start -> run_led
run_led -- "慢闪" -> slow_blink
run_led -- "快闪" -> fast_blink -> check_power
run_led -- "熄灭" -> off -> check_power
slow_blink -> network_led
fast_blink -> check_power
off -> check_power
network_led -- "亮" -> network_on -> dip_switch
network_led -- "不亮" -> network_off -> network_off
network_on -> dip_switch
dip_switch -> config_mode
dip_switch -> eth_mode
dip_switch -> wifi_mode
config_mode -> can_ping
eth_mode -> can_ping
wifi_mode -> can_ping
can_ping -- "能" -> ping_ok -> try_connect
can_ping -- "不能" -> ping_fail