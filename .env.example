# ============================================
# 智能物料管理系统 - 环境配置模板
# 使用方式: 复制本文件为 .env 并按需修改
#    cp .env.example .env
# .env 已加入 .gitignore，不会被提交
# ============================================

# --- PostgreSQL ---
# PG_HOST_PORT: 宿主机映射端口（默认 5432）
# PG_PASSWORD:  postgres 用户密码
PG_HOST_PORT=5432
PG_PASSWORD=postgres

# --- pgAdmin ---
# PGADMIN_HOST_PORT: 宿主机映射端口（默认 5050）
# PGADMIN_EMAIL:     登录邮箱
# PGADMIN_PASSWORD:  登录密码
PGADMIN_HOST_PORT=5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# --- 后端服务 ---
# DB_AUTO_MIGRATE: 启动时自动建表/迁移（开发=true, 生产=false）
DB_AUTO_MIGRATE=true

# XR_MATCH_WINDOW_SECONDS: XR 点料机自动匹配时间窗口（秒）
XR_MATCH_WINDOW_SECONDS=10

# LOG_LEVEL: 日志级别（debug / info / warning / error）
LOG_LEVEL=info
