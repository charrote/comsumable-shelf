# PostgreSQL 数据库密码（默认: postgres）
PG_PASSWORD=postgres

# pgAdmin 登录邮箱和密码
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# AMKN8702G 主控板（Modbus TCP）
MASTER_IP=host.docker.internal
MASTER_PORT=502
MASTER_STATION=200

# AMKN7141-CHXX LED 灯板
LED_PROTOCOL=protocol2
SLOT_BITS_PER_BOARD=20

# XR 点料机自动匹配时间窗口（秒）
XR_MATCH_WINDOW_SECONDS=10

# LED 命令工作线程数
LED_WORKER_COUNT=4

# 日志级别（debug / info / warning / error）
LOG_LEVEL=info
